{
  "name": "myfxboard",
  "version": "0.1.0",
  "description": "Personal MT5 multi-account dashboard with readonly access and token-gated settings",
  "main": "dist/src/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "test": "vitest",
    "test:ci": "vitest run --passWithNoTests",
    "db:migrate": "node --loader tsx db/runMigrations.ts",
    "db:seed": "node --loader tsx db/seed.ts",
    "lint": "eslint -c .eslintrc.json src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"db/**/*.ts\""
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
