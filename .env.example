# Database
DATABASE_URL=postgresql://dashboard:dashboard_pass@localhost:5432/myfxboard

# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Frontend
FRONTEND_PORT=3001

# Connector auth
CONNECTOR_SHARED_SECRET=change-this-secret

# Sync settings
SYNC_REQUEST_TIMEOUT_MS=5000
SYNC_HISTORY_CHUNK_SIZE=100
SYNC_HISTORY_RATE_LIMIT_MS=1500
SYNC_MIN_INGEST_INTERVAL_MS=500

# Backfill window (days)
BACKFILL_WINDOW_DAYS=90
