# Database
DATABASE_URL=postgresql://dashboard:dashboard_pass@localhost:5432/mt5_dashboard

# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Frontend
FRONTEND_PORT=3001

# JWT/Auth
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Sync settings
SYNC_REQUEST_TIMEOUT_MS=5000
SYNC_HISTORY_CHUNK_SIZE=100
SYNC_HISTORY_RATE_LIMIT_MS=1500

# Unlock token TTL (minutes)
UNLOCK_TOKEN_TTL_MINUTES=30

# Backfill window (days)
BACKFILL_WINDOW_DAYS=90
