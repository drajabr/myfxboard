# Database
DATABASE_URL=postgresql://dashboard:dashboard_pass@localhost:5432/myfxboard

# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Frontend
FRONTEND_PORT=3001

# JWT/Auth
# Optional: if omitted, server generates a random token at first unlock access,
# logs it to console, and returns it once in the unlock response.
# JWT_SECRET=

# Sync settings
SYNC_REQUEST_TIMEOUT_MS=5000
SYNC_HISTORY_CHUNK_SIZE=100
SYNC_HISTORY_RATE_LIMIT_MS=1500

# Unlock token TTL (minutes)
UNLOCK_TOKEN_TTL_MINUTES=30

# Backfill window (days)
BACKFILL_WINDOW_DAYS=90
